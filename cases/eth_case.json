{
  "case_name": "Ethernet Module Test",
  "description": "Complete Ethernet module testing including connectivity and speed",
  "module": "eth",
  "functions": [
    {
      "name": "test_eth",
      "params": {
        "ip": "192.168.100.1",
        "count": 4,
        "interface": "${interfaces.eth}"
      },
      "enabled": true
    },
    {
      "name": "test_eth",
      "params": {
        "ip": "8.8.8.8",
        "count": 4,
        "interface": "${interfaces.eth}"
      },
      "enabled": true
    }
  ],
  "execution": "sequential",
  "timeout": 60,
  "retry": 2,
  "retry_interval": 5,
  "precheck": true,
  "required_interfaces": {
    "eth": {
      "select": "auto",
      "required": true
    }
  }
}