  "module": "gpio",
  "functions": [
    {
      "name": "test_gpio",
      "params": {
        "pin": 17,
        "mode": "output",
        "value": 1
      },
      "enabled": true,
      "note": "基础 GPIO 测试"
    },
    {
      "name": "test_40pin_gpio",
      "params": {
        "pin": 11,
        "mode": "output",
        "value": 1
      },
      "enabled": false,
      "note": "40Pin 排针 GPIO 测试 (物理引脚 11 -> GPIO17)"
    }
  ],
  "execution": "sequential",
  "timeout": 30,
  "retry": 1,
  "retry_interval": 2
}
