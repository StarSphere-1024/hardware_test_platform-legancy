{
  "case_name": "UART Loopback Test",
  "description": "UART serial communication loopback test",
  "module": "uart",
  "functions": [
    {
      "name": "test_uart",
      "params": {
        "port": "/dev/ttyUSB0",
        "baudrate": 115200,
        "loopback": true
      },
      "enabled": true
    }
  ],
  "execution": "sequential",
  "timeout": 30,
  "retry": 1,
  "retry_interval": 2
}
