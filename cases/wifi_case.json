{
  "case_name": "WiFi Test",
  "description": "WiFi 扫描、连接和 ping 测试",
  "module": "wifi",
  "functions": [
    {
      "name": "test_wifi",
      "params": {
        "ssid": "YourNetworkSSID",
        "password": "YourPassword"
